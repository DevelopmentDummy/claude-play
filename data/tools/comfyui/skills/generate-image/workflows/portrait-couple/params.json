    "height": {
      "node": "4",
      "field": "height",
      "type": "number",
      "default": 1216
    },
    "mask_base_width": {
      "node": "52",
      "field": "width",
      "type": "number",
      "default": 832
    },
    "mask_base_height": {
      "node": "52",
      "field": "height",
      "type": "number",
      "default": 1216
    },
    "mask_region_width": {
      "node": "53",
      "field": "width",
