{
  "description": "배경/CG 장면 (1216x832 가로) — LoRA x8 + FaceDetailer + 4x Upscale",
  "compatibility": {
    "requires": { "loader": "checkpoint_simple" },
    "incompatible_message": "scene 패키지는 단일 세이프텐서 체크포인트(CheckpointLoaderSimple)만 지원합니다. UNET 분리 로드 체크포인트(animaCatTower 등)는 'anima-mixed-scene' 패키지를 사용하세요."
  },
  "features": {
    "checkpoint_auto": true,
    "lora_injection": true,
    "lora_couple_branches": false,
    "seed_randomize": true,
    "trigger_tags": true,
    "detailer_chain": true
  },
  "detailer_chain": {
    "source": {
      "node": "6",
      "output": 0
    },
    "sink": {
      "node": "30",
      "field": "image"
    }
  },
  "params": {
    "prompt": {
      "node": "2",
      "field": "text",
      "type": "string",
      "required": true
    },
    "negative_prompt": {
      "node": "3",
      "field": "text",
      "type": "string",
      "default": "bad quality, worst quality, worst detail, sketch, censored, watermark, signature, extra fingers, mutated hands, bad anatomy"
    },
    "width": {
      "node": "4",
      "field": "width",
      "type": "number",
      "default": 1216
    },
    "height": {
      "node": "4",
      "field": "height",
      "type": "number",
      "default": 832
    },
    "steps": {
      "node": "5",
      "field": "steps",
      "type": "number",
      "default": 35
    },
    "cfg": {
      "node": "5",
      "field": "cfg",
      "type": "number",
      "default": 6
    },
    "seed": {
      "node": "5",
      "field": "seed",
      "type": "number",
      "default": -1
    },
    "detailer_face": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable face detailer"
    },
    "detailer_hand": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable hand detailer"
    },
    "detailer_pussy": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable pussy detailer"
    },
    "detailer_anus": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable anus detailer"
    }
  }
}
