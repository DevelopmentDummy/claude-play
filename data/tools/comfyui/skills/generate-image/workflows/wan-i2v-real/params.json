{
  "description": "WAN 2.2 i2v 영상 베이스 패키지(실사 여행 푸티지용) — wan-i2v와 동일한 lightning 2-stage FLF2V에 실사 특화 RealESRGAN_x2plus 업스케일(net 2x, 832x480→1664x960) 기본 내장. end_image로 키프레임 체이닝. 키프레임-FLF 모션 클립의 기본 패키지.",
  "features": {
    "checkpoint_auto": false,
    "lora_injection": false,
    "lora_couple_branches": false,
    "seed_randomize": false,
    "trigger_tags": false,
    "detailer_chain": false
  },
  "params": {
    "start_image": {
      "node": "8",
      "field": "image",
      "type": "string",
      "required": true,
      "description": "ComfyUI input 폴더 기준 시작 프레임 파일명"
    },
    "end_image": {
      "type": "string",
      "description": "선택 — 끝 프레임 파일명(FLF2V 키프레임 체이닝). loop보다 우선."
    },
    "prompt": {
      "node": "6",
      "field": "text",
      "type": "string",
      "required": true,
      "description": "모션 묘사 자연어 프롬프트 (2차 동작 포함 권장)"
    },
    "negative_prompt": {
      "node": "7",
      "field": "text",
      "type": "string",
      "default": "jump cut, scene change, teleport, morphing, distorted face, extra limbs, text, watermark, frozen person, motionless person, mannequin, blurry, low quality, worst quality, jpeg artifacts",
      "description": "네거티브 프롬프트"
    },
    "width": {
      "node": "10",
      "field": "width",
      "type": "number",
      "default": 832
    },
    "height": {
      "node": "10",
      "field": "height",
      "type": "number",
      "default": 480
    },
    "length": {
      "node": "10",
      "field": "length",
      "type": "number",
      "default": 81,
      "description": "프레임 수 (16fps 기준 49f≈3초, 81f≈5초)"
    },
    "fps": {
      "node": "14",
      "field": "fps",
      "type": "number",
      "default": 16
    },
    "upscale_model": {
      "node": "15",
      "field": "model_name",
      "type": "string",
      "default": "RealESRGAN_x2plus.pth",
      "description": "업스케일러 모델 (실사 RealESRGAN_x2plus / 애니 4x-AnimeSharp 등)"
    },
    "upscale_scale": {
      "node": "17",
      "field": "scale_by",
      "type": "number",
      "default": 1,
      "description": "업스케일 후 추가 배율 (x2 모델은 1.0, x4 모델은 0.5로 net 2x)"
    },
    "seed": {
      "type": "number",
      "default": -1,
      "description": "-1이면 랜덤. 두 스테이지 동일"
    },
    "steps": {
      "type": "number",
      "default": 6,
      "description": "lightning 총 step. high/low 절반 분할"
    },
    "cfg": {
      "type": "number",
      "default": 1
    },
    "loop": {
      "type": "boolean",
      "default": false,
      "description": "true면 FLF2V 닫힌 루프"
    },
    "upscale": {
      "type": "boolean",
      "default": true,
      "description": "false면 업스케일 생략(native 출력, 빠른 초벌용)"
    }
  }
}
