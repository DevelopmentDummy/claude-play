{
  "_meta": {
    "description": "기존 이미지에서 얼굴을 YOLO 감지하여 256x256 아이콘으로 크롭",
    "outputs": {
      "icon": { "node": "41", "description": "YOLO 얼굴 크롭 아이콘 (256x256)" }
    },
    "params": {
      "image": { "node": "10", "field": "image", "required": true }
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "input.png" },
    "_meta": { "title": "load-source-image" }
  },
  "20": {
    "class_type": "UltralyticsDetectorProvider",
    "inputs": { "model_name": "bbox/face_yolov8m.pt" },
    "_meta": { "title": "face-detector" }
  },
  "42": {
    "class_type": "BboxDetectorSEGS",
    "inputs": {
      "bbox_detector": ["20", 0],
      "image": ["10", 0],
      "threshold": 0.5,
      "dilation": 0,
      "crop_factor": 1.3,
      "drop_size": 10,
      "labels": "all"
    },
    "_meta": { "title": "face-detect-for-icon" }
  },
  "43": {
    "class_type": "SEGSToImageList",
    "inputs": {
      "segs": ["42", 0],
      "fallback_image_opt": ["10", 0]
    },
    "_meta": { "title": "face-crop-extract" }
  },
  "40": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["43", 0],
      "width": 256, "height": 256,
      "upscale_method": "lanczos",
      "crop": "center"
    },
    "_meta": { "title": "face-crop-resize (256x256)" }
  },
  "41": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "icon", "images": ["40", 0] },
    "_meta": { "title": "save-icon" }
  }
}
