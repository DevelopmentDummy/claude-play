{
  "description": "품질 모드에 따라 steps/cfg/해상도를 자동 조정하는 초상 패키지",
  "compatibility": {
    "requires": { "loader": "checkpoint_simple" },
    "incompatible_message": "portrait-balanced 패키지는 단일 세이프텐서 체크포인트(CheckpointLoaderSimple)만 지원합니다. UNET 분리 로드 체크포인트는 'anima-mixed-scene' 패키지를 사용하세요."
  },
  "features": {
    "checkpoint_auto": true,
    "lora_injection": true,
    "lora_couple_branches": false,
    "seed_randomize": true,
    "trigger_tags": true,
    "detailer_chain": true
  },
  "detailer_chain": {
    "source": {
      "node": "6",
      "output": 0
    },
    "sink": {
      "node": "30",
      "field": "image"
    }
  },
  "params": {
    "prompt": {
      "node": "2",
      "field": "text",
      "type": "string",
      "required": true,
      "description": "생성 프롬프트"
    },
    "negative_prompt": {
      "node": "3",
      "field": "text",
      "type": "string",
      "default": "bad quality, worst quality, worst detail, sketch, censored, watermark, signature, extra fingers, mutated hands, bad anatomy",
      "description": "네거티브 프롬프트"
    },
    "seed": {
      "node": "5",
      "field": "seed",
      "type": "number",
      "default": -1,
      "description": "생성 시드"
    },
    "quality_mode": {
      "type": "string",
      "default": "balanced",
      "description": "fast | balanced | detail"
    },
    "detailer_face": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable face detailer"
    },
    "detailer_hand": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable hand detailer"
    },
    "detailer_pussy": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable pussy detailer"
    },
    "detailer_anus": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable anus detailer"
    }
  }
}
