{
  "description": "캐릭터 프로필 (832x1216 세로) — portrait + 얼굴 크롭 아이콘 동시 생성",
  "compatibility": {
    "requires": { "loader": "checkpoint_simple" },
    "incompatible_message": "profile 패키지는 단일 세이프텐서 체크포인트(CheckpointLoaderSimple)만 지원합니다. UNET 분리 로드 체크포인트는 'anima-mixed-scene' 패키지를 사용하세요."
  },
  "features": {
    "checkpoint_auto": true,
    "lora_injection": true,
    "lora_couple_branches": false,
    "seed_randomize": true,
    "trigger_tags": true,
    "detailer_chain": true
  },
  "detailer_chain": {
    "source": {
      "node": "6",
      "output": 0
    },
    "sink": {
      "node": "30",
      "field": "image"
    }
  },
  "outputs": {
    "profile": {
      "node": "7",
      "description": "전신/상반신 프로필 이미지"
    },
    "icon": {
      "node": "41",
      "description": "YOLO 얼굴 크롭 아이콘 (256x256)"
    }
  },
  "params": {
    "prompt": {
      "node": "2",
      "field": "text",
      "type": "string",
      "required": true
    },
    "negative_prompt": {
      "node": "3",
      "field": "text",
      "type": "string",
      "default": "bad quality, worst quality, worst detail, sketch, censored, watermark, signature, extra fingers, mutated hands, bad anatomy"
    },
    "width": {
      "node": "4",
      "field": "width",
      "type": "number",
      "default": 832
    },
    "height": {
      "node": "4",
      "field": "height",
      "type": "number",
      "default": 1216
    },
    "steps": {
      "node": "5",
      "field": "steps",
      "type": "number",
      "default": 24
    },
    "cfg": {
      "node": "5",
      "field": "cfg",
      "type": "number",
      "default": 6.5
    },
    "seed": {
      "node": "5",
      "field": "seed",
      "type": "number",
      "default": -1
    },
    "detailer_face": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable face detailer"
    },
    "detailer_hand": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable hand detailer"
    },
    "detailer_pussy": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable pussy detailer"
    },
    "detailer_anus": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable anus detailer"
    }
  }
}
