{
  "description": "캐릭터 프로필 (832x1216 세로) — portrait + 얼굴 크롭 아이콘 동시 생성",
  "features": {
    "checkpoint_auto": true,
    "lora_injection": true,
    "lora_couple_branches": false,
    "seed_randomize": true,
    "trigger_tags": true
  },
  "outputs": {
    "profile": {
      "node": "7",
      "description": "전신/상반신 프로필 이미지"
    },
    "icon": {
      "node": "41",
      "description": "YOLO 얼굴 크롭 아이콘 (256x256)"
    }
  },
  "params": {
    "prompt": {
      "node": "2",
      "field": "text",
      "type": "string",
      "required": true
    },
    "negative_prompt": {
      "node": "3",
      "field": "text",
      "type": "string",
      "default": "bad quality, worst quality, worst detail, sketch, censored, watermark, signature, extra fingers, mutated hands, bad anatomy"
    },
    "width": {
      "node": "4",
      "field": "width",
      "type": "number",
      "default": 832
    },
    "height": {
      "node": "4",
      "field": "height",
      "type": "number",
      "default": 1216
    },
    "steps": {
      "node": "5",
      "field": "steps",
      "type": "number",
      "default": 24
    },
    "cfg": {
      "node": "5",
      "field": "cfg",
      "type": "number",
      "default": 6.5
    },
    "seed": {
      "node": "5",
      "field": "seed",
      "type": "number",
      "default": -1
    }
  }
}
