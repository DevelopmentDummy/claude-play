{
  "description": "MatrixHentai 스모크 테스트용 img2img — 입력 이미지 1장을 받아 Danbooru 태그 프롬프트로 재페인팅",
  "compatibility": {
    "requires": { "loader": "checkpoint_simple" },
    "incompatible_message": "matrixhentai-img2img-smoke는 단일 세이프텐서 체크포인트만 지원합니다."
  },
  "features": {
    "checkpoint_auto": false,
    "lora_injection": true,
    "lora_couple_branches": false,
    "seed_randomize": true,
    "trigger_tags": false
  },
  "params": {
    "prompt": {
      "node": "2",
      "field": "text",
      "type": "string",
      "required": true,
      "description": "MatrixHentai용 Danbooru 태그 프롬프트"
    },
    "negative_prompt": {
      "node": "3",
      "field": "text",
      "type": "string",
      "default": "low quality, worst quality, blurry, extra fingers, broken hands, bad anatomy, deformed face, distorted eyes, overpainted details, muddy colors, oversharpen, duplicate"
    },
    "input_image": {
      "node": "4",
      "field": "image",
      "type": "string",
      "required": true,
      "description": "세션 images/ 기준 입력 이미지 경로"
    },
    "steps": {
      "node": "6",
      "field": "steps",
      "type": "number",
      "default": 24
    },
    "cfg": {
      "node": "6",
      "field": "cfg",
      "type": "number",
      "default": 5.2
    },
    "denoise": {
      "node": "6",
      "field": "denoise",
      "type": "number",
      "default": 0.4
    },
    "seed": {
      "node": "6",
      "field": "seed",
      "type": "number",
      "default": -1
    }
  }
}
