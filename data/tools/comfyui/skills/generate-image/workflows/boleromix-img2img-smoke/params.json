{
  "description": "Boleromix teacher img2img — 입력 이미지를 Danbooru 태그로 재페인팅 + 4-Detailer 체인",
  "features": {
    "checkpoint_auto": false,
    "lora_injection": true,
    "lora_couple_branches": false,
    "seed_randomize": true,
    "trigger_tags": false,
    "detailer_chain": true
  },
  "detailer_chain": {
    "source": {
      "node": "7",
      "output": 0
    },
    "sink": {
      "node": "8",
      "field": "images"
    }
  },
  "params": {
    "prompt": {
      "node": "2",
      "field": "text",
      "type": "string",
      "required": true,
      "description": "Boleromix용 Danbooru 태그 프롬프트"
    },
    "negative_prompt": {
      "node": "3",
      "field": "text",
      "type": "string",
      "default": "low quality, worst quality, blurry, extra fingers, broken hands, bad anatomy, deformed face, distorted eyes, overpainted details, muddy colors, oversharpen, duplicate"
    },
    "input_image": {
      "node": "4",
      "field": "image",
      "type": "string",
      "required": true,
      "description": "세션 images/ 기준 입력 이미지 경로"
    },
    "steps": {
      "node": "6",
      "field": "steps",
      "type": "number",
      "default": 24
    },
    "cfg": {
      "node": "6",
      "field": "cfg",
      "type": "number",
      "default": 5.2
    },
    "denoise": {
      "node": "6",
      "field": "denoise",
      "type": "number",
      "default": 0.55
    },
    "seed": {
      "node": "6",
      "field": "seed",
      "type": "number",
      "default": -1
    },
    "detailer_face": {
      "type": "boolean",
      "default": true,
      "description": "Enable/disable face detailer"
    },
    "detailer_hand": {
      "type": "boolean",
      "default": false,
      "description": "Enable/disable hand detailer"
    },
    "detailer_pussy": {
      "type": "boolean",
      "default": false,
      "description": "Enable/disable pussy detailer"
    },
    "detailer_anus": {
      "type": "boolean",
      "default": false,
      "description": "Enable/disable anus detailer"
    }
  }
}
