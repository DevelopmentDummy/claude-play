{
  "_description": "엔진 액션 메타데이터. 사용자가 패널 버튼으로 할 수 있는 모든 액션을 AI도 선택지로 제안할 수 있다.",

  "actions": {
    "set_schedule": {
      "name": "스케줄 설정",
      "description": "스케줄 슬롯(1~3)에 활동을 배정한다.",
      "available_when": { "turn_phase": "setup" },
      "params": { "slots": "object ({ 1: 'activity_id', 2: 'activity_id', 3: 'activity_id' })" },
      "category": "schedule",
      "choice_examples": [
        "검술에 집중! → { slots: { 1: 'sword_dojo', 2: 'sword_dojo', 3: 'rest' } }",
        "균형 잡힌 스케줄 → { slots: { 1: 'private_school', 2: 'job_inn', 3: 'rest' } }"
      ]
    },

    "confirm_schedule": {
      "name": "스케줄 확정",
      "description": "설정된 스케줄을 확정하고 실행 페이즈로 전환.",
      "available_when": { "turn_phase": "setup", "has_any_schedule": true },
      "params": {},
      "category": "schedule"
    },

    "advance_slot": {
      "name": "스케줄 슬롯 진행",
      "description": "다음 슬롯 1개를 실행한다. slot3이면 월 전환도 자동 포함 (원자적).",
      "available_when": { "turn_phase": "executing", "current_slot_lt": 3 },
      "params": {},
      "category": "schedule"
    },

    "enter_competition": {
      "name": "대회 등록",
      "description": "계절 축제 대회에 참가. 대회 모달이 열리며 경쟁 시작.",
      "available_when": { "competitions_available": true, "not_already_entered": true },
      "params": { "competition_id": "string" },
      "category": "event",
      "choice_examples": [
        "무술대회 출전! → { competition_id: 'martial_tournament' }"
      ]
    },

    "adventure_fight": {
      "name": "전투",
      "description": "모험 중 현재 적과 1회 전투.",
      "available_when": { "__adventure_active": true, "__adventure_status": "encounter" },
      "params": {},
      "category": "adventure"
    },

    "adventure_use_item": {
      "name": "모험 중 아이템",
      "description": "모험 전투 중 소모품 사용.",
      "available_when": { "__adventure_active": true, "has_consumables": true },
      "params": { "item": "string" },
      "category": "adventure"
    },

    "adventure_retreat": {
      "name": "후퇴",
      "description": "모험에서 도주 (획득 보상 유지).",
      "available_when": { "__adventure_active": true },
      "params": {},
      "category": "adventure"
    },

    "adventure_complete": {
      "name": "모험 완료",
      "description": "모험 종료 처리.",
      "available_when": { "__adventure_active": true },
      "params": {},
      "category": "adventure"
    },

    "buy_item": {
      "name": "아이템 구매",
      "description": "상점에서 아이템 구매.",
      "available_when": { "gold_gte_cost": true },
      "params": { "item": "string", "quantity": "number (optional)" },
      "category": "shop"
    },

    "use_item": {
      "name": "아이템 사용",
      "description": "인벤토리 소모품 사용.",
      "available_when": { "has_item": true },
      "params": { "item": "string" },
      "category": "inventory"
    },

    "equip": {
      "name": "장비/의상 착용",
      "description": "장비 또는 의상 착용.",
      "available_when": { "has_equipment_or_outfit": true },
      "params": { "type": "string", "item": "string", "outfit_id": "string" },
      "category": "inventory"
    },

    "talk_to_father": {
      "name": "아빠와 대화",
      "description": "아빠와 대화한다. 주제에 따라 소폭 스탯 변동. 용사 배경 시 무술 보너스. 월 1회 무료.",
      "available_when": { "turn_phase": "setup", "father_not_talked": true },
      "params": { "topic": "string (martial/study/life/play)" },
      "category": "family",
      "choice_examples": [
        "아빠한테 무술 배우자! → { topic: 'martial' }",
        "아빠한테 고민 상담하자 → { topic: 'life' }",
        "아빠랑 놀자! → { topic: 'play' }"
      ]
    }
  },

  "_internal_actions": {
    "_description": "아래 액션들은 시스템 내부에서만 호출됨. AI 선택지에 절대 포함하지 마라.",
    "turn_transition": "advance_slot에 자동 병합됨 — 별도 호출 불필요",
    "run_competition": "enter_competition이 모달을 열면 자동 실행",
    "apply_setup": "초기 설정 패널이 트리거",
    "check_unlocks": "시스템 내부",
    "generate_wish": "시스템 내부",
    "check_ending": "시스템 내부",
    "adventure": "레거시 자동전투",
    "add_activity": "AI가 MCP로 직접 호출 (선택지 아님)"
  },

  "choice_action_guide": {
    "rules": [
      "_internal_actions에 있는 액션은 선택지에 절대 넣지 마라",
      "available_when 조건을 반드시 확인할 것",
      "set_schedule + confirm_schedule은 세트로 제안하거나 순차 제안",
      "advance_slot은 slot3이면 월 전환까지 원자적으로 처리 — 안전하게 단독 제안 가능",
      "모험 액션은 __adventure가 활성일 때만",
      "패널 열기: { tool: '__open_modal', args: { name: 'schedule' } }"
    ]
  }
}
