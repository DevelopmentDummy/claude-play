# Claude Play Configuration
# Copy this to .env.local and fill in your values

# === Core ===
PORT=3340                    # Main server port (TTS=PORT+1, GPU Manager=PORT+2)
DATA_DIR=./data              # Data directory path

# === Authentication ===
ADMIN_PASSWORD=              # Admin login password (leave empty to disable auth)

# === ComfyUI (optional) ===
COMFYUI_HOST=127.0.0.1       # ComfyUI host
COMFYUI_PORT=8188             # ComfyUI port
COMFYUI_DIR=                  # ComfyUI install path (for model downloads; auto-detected for submodule)
COMFYUI_AUTOSTART=false       # If true and COMFYUI_DIR is set, spawn ComfyUI as a child process on server start
# COMFYUI_PYTHON=             # Override Python interpreter (default: <COMFYUI_DIR>/venv/Scripts/python.exe on Windows, venv/bin/python on POSIX)

# === API Keys (optional) ===
OPENAI_IMAGE_BACKEND=codex  # Image backend for the OpenAI/GPT tool: "codex" (default, via Codex CLI + ChatGPT subscription, no per-call cost) | "api" (metered OpenAI Responses API, needs OPENAI_API_KEY)
OPENAI_API_KEY=           # OpenAI API key — only required when OPENAI_IMAGE_BACKEND=api
OPENAI_IMAGE_MODEL=gpt-5.5  # Responses API model (only used when OPENAI_IMAGE_BACKEND=api)
GEMINI_API_KEY=               # Gemini image generation API key
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview  # Gemini image generation model
CIVITAI_API_KEY=              # CivitAI model download API key

# === Provider routing ===
# Gemini CLI (text/chat provider) is retired — Google stopped serving free/Pro/Ultra
# requests (2026-06). Keep this true so Gemini runs through Antigravity instead: the model
# picker hides the Gemini group, and gemini-* model ids transparently route to Antigravity
# (gemini-…-pro → Pro tier, others → Flash) so existing sessions/personas keep working.
# New picks: use the "Gemini (Antigravity)" options (Gemini 3.5 Flash / 3.1 Pro).
# NOTE: does NOT affect Gemini IMAGE generation (GEMINI_API_KEY above) — that is separate.
NEXT_PUBLIC_DISABLE_GEMINI=true

# === External LLM Codex gateway routing (optional) ===
# These are inherited by spawned Claude Code / Codex CLI processes.
# Claude Play does not validate these values; the target CLI/gateway validates them.
# Keep them commented unless you select an "External Gateway" model.
#
# Existing Claude/Codex/Gemini OAuth models do not use these values.
# External Gateway models run through Codex app-server with per-process config.
# The gateway must expose an OpenAI Responses-compatible /v1 endpoint.
# CODEX_EXTERNAL_BASE_URL=http://localhost:4000/v1
# CODEX_EXTERNAL_API_KEY=      # Optional, used when the gateway requires bearer auth
# CODEX_EXTERNAL_ENV_KEY=CODEX_EXTERNAL_API_KEY
#
# Provider API keys for your gateway/router only, if it reads upstream keys from env:
# MOONSHOT_API_KEY=           # Moonshot API key for custom gateways only; native Kimi CLI uses its own login
# DEEPSEEK_API_KEY=           # DeepSeek API key
# OPENROUTER_API_KEY=         # OpenRouter API key
# QWEN_API_KEY=               # Qwen-compatible provider API key
# ZAI_API_KEY=                # GLM/Z.ai API key

# === TTS ===
TTS_ENABLED=true              # Enable/disable TTS globally

# === Advanced (usually no need to change) ===
# TTS_PORT=                   # Override TTS port (default: PORT+1)
# GPU_MANAGER_PORT=           # Override GPU Manager port (default: PORT+2)
# GPU_MANAGER_PYTHON=python   # Python executable for GPU Manager
